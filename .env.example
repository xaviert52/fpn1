# Frontend environment
# Optional hard override (highest priority)
# VITE_API_URL=http://localhost:3001

# Deployment mode selector: auto | vercel | amplify | inhouse
VITE_DEPLOY_MODE=auto

# Base URLs by target platform
VITE_API_URL_VERCEL=https://api.tu-dominio-vercel.com
VITE_API_URL_AMPLIFY=https://api.tu-dominio-amplify.com

# In-house defaults
VITE_API_URL_INHOUSE=https://api.tu-dominio-interno.com
VITE_API_URL_INHOUSE_HTTP=http://192.168.1.50:3001
VITE_API_URL_INHOUSE_HTTPS=https://api.tu-dominio-interno.com
